{
  "expo": {
    "name": "MemoriaCam",
    "slug": "MemoriaCam",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/memoria_cam_icon.png",
    "scheme": "memoriacam",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/memoria_cam_icon.png"
    },
    "android": {
      "icon": "./assets/images/memoria_cam_icon.png",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.MemoriaCam"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/memoria_cam_icon.png",
      "icon": "./assets/images/memoria_cam_icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-google-signin/google-signin",
      "expo-web-browser",
      "expo-audio",
      "expo-video",
      "react-native-compressor"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}